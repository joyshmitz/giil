#!/usr/bin/env bash
#
# giil - Get Image [from] Internet Link (v3.0)
# Downloads images from cloud sharing services (iCloud, Dropbox, Google Photos, Google Drive)
#
# FEATURES:
#   - Primary: Click Download button (direct file acquisition)
#   - Fallback 1: Network interception (largest CDN image)
#   - Fallback 2: Element screenshot
#   - Fallback 3: Viewport screenshot
#   - EXIF datetime extraction for filenames
#   - Sharp + MozJPEG for superior compression
#   - HEIC/HEIF support with platform fallbacks
#   - Cookie/overlay auto-dismissal
#   - Album mode (--all) for downloading entire shared albums
#   - JSON output mode for scripting
#
# Usage:
#   giil <share-url> [<share-url> ...] [options]
#
# Multiple URLs: Playwright-backed platforms (iCloud / Google Photos / Drive)
# are processed in ONE headless browser using multiple isolated tabs/contexts
# with bounded concurrency (default 3), instead of launching a browser per URL
# (issue #4). Dropbox URLs keep their separate fast direct-download path.
# Env knobs:
#   GIIL_BATCH_CONCURRENCY=N   Max concurrent tabs in a batch (default 3)
#   GIIL_NO_BATCH=1            Force the legacy one-process-per-URL behavior
#
# Options:
#   --base64         Output image as base64 to stdout
#   --format FMT     Output format: json|toon (structured output)
#   --json           Output JSON metadata (alias for --format json)
#   --all            Download all photos from shared album
#   --output DIR     Output directory (default: current)
#   --preserve       Keep original bytes (skip MozJPEG compression)
#   --convert FMT    Convert to format: jpeg, png, webp
#   --quality N      JPEG/WebP quality (default: 85)
#   --update         Force update Playwright/dependencies
#   --debug          Save debug artifacts on failure
#   --timeout N      Page load timeout in seconds (default: 60)
#   --help           Show help message
#   --version        Show version
#

set -euo pipefail

